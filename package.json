{
    "name": "focus-buddy",
    "private": true,
    "version": "1.0.0",
    "description": "The ultimate desktop companion to keep you productive, hydrated, and healthy.",
    "author": "DamianAI1234",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
        "electron:pack:win": "electron-builder --win -c.extraMetadata.main=electron/main.js",
        "electron:pack:mac": "electron-builder --mac -c.extraMetadata.main=electron/main.js",
        "start": "concurrently -k \"npm run dev\" \"npm run electron\""
    },
    "build": {
        "appId": "com.focus.buddy",
        "productName": "Focus Buddy",
        "directories": {
            "output": "release/"
        },
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "dmg"
            ]
        },
        "win": {
            "target": [
                "nsis"
            ]
        }
    },
    "dependencies": {
        "lucide-react": "^0.344.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.24",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^29.1.0",
        "electron-builder": "^24.13.3",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.6",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.3",
        "typescript": "^5.2.2",
        "vite": "^5.2.0",
        "wait-on": "^7.2.0"
    }
}